{
  "extends": "@finsweet/tsconfig",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": "./",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "$utils/*": ["shared/utils/*"]
    },
    "types": ["@finsweet/ts-utils"]
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "dist"]
}
