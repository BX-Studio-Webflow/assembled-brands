{
	"name": "server",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev --env development --remote",
		"deploy:development": "wrangler deploy --minify --env development",
		"deploy:production": "wrangler deploy --minify --env production",
		"check": "tsc --noEmit",
		"lint": "eslint ./src",
		"lint:fix": "eslint ./src --fix",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:development": "wrangler d1 migrations apply DB --env development --remote",
		"db:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
		"db:studio": "drizzle-kit migrate && drizzle-kit studio",
		"db:create": "wrangler d1 create",
		"db:delete": "wrangler d1 delete"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.19",
		"@finsweet/eslint-config": "^3.0.3",
		"drizzle-kit": "^0.31.7",
		"eslint": "^9.19.0",
		"typescript": "^5.5.2",
		"typescript-eslint": "^8.23.0",
		"vitest": "~3.2.0",
		"wrangler": "^4.52.1"
	},
	"dependencies": {
		"@aws-sdk/client-mediaconvert": "^3.943.0",
		"@aws-sdk/client-s3": "^3.943.0",
		"@aws-sdk/s3-request-presigner": "^3.943.0",
		"@hono/zod-validator": "^0.7.5",
		"dayjs": "^1.11.19",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.10.7",
		"http-status-codes": "^2.3.0",
		"libphonenumber-js": "^1.12.31",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"zod": "^4.1.13"
	}
}